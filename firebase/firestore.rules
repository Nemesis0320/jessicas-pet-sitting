rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isMemberOfHome(homeId) {
      let home = get(/databases/$(database)/documents/homes/$(homeId)).data;
      return isSignedIn() && (request.auth.uid in home.residents);
    }

    // Admins collection - only admins can read/write
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }

    // User profiles - users can read/write their own; admins can read all
    match /users/{uid} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // Homes - household members or admins can read/write their own home
    match /homes/{homeId} {
      allow read:   if isAdmin() || isMemberOfHome(homeId);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.residents);
      allow update: if isAdmin() || isMemberOfHome(homeId);
      allow delete: if isAdmin();
    }

    // Pets - same access as the home they belong to
    match /pets/{petId} {
      allow read, write: if isAdmin() ||
        isMemberOfHome(resource.data.home) ||
        (request.resource != null && isMemberOfHome(request.resource.data.home));
    }

    // Appointments - read by the homeowner, written by them; admins can update status
    match /appointments/{apptId} {
      allow read:   if isAdmin() || isMemberOfHome(resource.data.homeId);
      allow create: if isSignedIn() && isMemberOfHome(request.resource.data.homeId);
      allow update: if isAdmin() || isMemberOfHome(resource.data.homeId);
      allow delete: if isAdmin() || isMemberOfHome(resource.data.homeId);
    }

    // Invoices - admins write, owners read
    match /invoices/{invId} {
      allow read:   if isAdmin() || isMemberOfHome(resource.data.homeId);
      allow write:  if isAdmin();
    }

    // Notifications - users can read their own; system creates them
    match /notifications/{notifId} {
      allow read:   if isSignedIn() && request.auth.token.email == resource.data.to;
      allow create: if isAdmin() || isSignedIn();
      allow update: if isSignedIn() && request.auth.token.email == resource.data.to;
      allow delete: if isAdmin();
    }
  }
}
